{
  "name": "@asst3d/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx watch --ignore \"**/node_modules/**\" src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "gen:samples": "tsx scripts/gen-samples.ts"
  },
  "dependencies": {
    "@asst3d/shared": "workspace:*",
    "@aws-sdk/client-s3": "^3.1079.0",
    "@fastify/static": "^8.0.0",
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/extensions": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "better-sqlite3": "^11.10.0",
    "bs58": "^6.0.0",
    "fastify": "^5.3.0",
    "meshoptimizer": "^1.2.0",
    "pg": "^8.22.0",
    "sharp": "^0.35.3",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.20.0",
    "@types/three": "^0.169.0",
    "three": "^0.169.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
