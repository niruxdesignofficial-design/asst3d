{
  "name": "@asst3d/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx watch --ignore \"**/node_modules/**\" src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "gen:samples": "tsx scripts/gen-samples.ts"
  },
  "dependencies": {
    "@asst3d/shared": "workspace:*",
    "better-sqlite3": "^11.10.0",
    "fastify": "^5.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.14.0",
    "three": "^0.169.0",
    "@types/three": "^0.169.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
