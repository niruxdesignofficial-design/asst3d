# ===== Formora server config =====
# Las API keys viven SOLO acá (server). Nunca en el frontend ni en el repo.

# Proveedor de generación: 3daistudio | meshy | mock
# Si no se especifica, se infiere por la key cargada (sin keys => mock).
PROVIDER=

# 3D AI Studio (api.3daistudio.com)
THREEDAI_API_KEY=

# Meshy (api.meshy.ai) — proveedor alternativo
MESHY_API_KEY=

# Puerto del server
PORT=8787

# ---- Control de uso (server-authoritative) ----
# Generaciones gratis por usuario (device+IP)
FREE_GENERATIONS_PER_USER=3
# Tope global de generaciones por mes (acorde a tu plan de Meshy)
GLOBAL_MONTHLY_CAP=200
# Si el balance de créditos de Meshy cae por debajo de esto, la app frena
MESHY_MIN_BALANCE=20
# Rate limiting: máx. requests de generación por ventana
RATE_LIMIT_MAX_PER_MINUTE=3
RATE_LIMIT_MAX_PER_HOUR=10

# ---- Web3 (apagado hasta que el dueño lo configure) ----
PAYMENTS_ENABLED=false
# Dirección del token / wallet de cobro (a definir)
TOKEN_GATE_ADDRESS=
